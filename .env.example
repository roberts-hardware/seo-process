# SEO Process - Environment Configuration
# Copy this file to .env and fill in your credentials
# cp .env.example .env

# ============================================================
# Google Cloud / Google Search Console
# ============================================================

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT="your-project-id"

# Google Search Console Access Token (from gcloud auth)
# Generate with: gcloud auth application-default print-access-token
GSC_ACCESS_TOKEN=""

# Alternative: Service Account JSON path
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# ============================================================
# DataForSEO API (for keyword discovery)
# ============================================================

# Get your credentials at: https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN="your-login@example.com"
DATAFORSEO_PASSWORD="your-api-password"

# ============================================================
# Team Notifications (Optional)
# ============================================================

# Slack Webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""

# Email notifications
# Requires mail command to be configured on server
EMAIL_TO=""

# ============================================================
# GitHub (for auto-sync)
# ============================================================

# Git user info (for commits)
GIT_USER_NAME="SEO Process Bot"
GIT_USER_EMAIL="seo-bot@yourcompany.com"

# GitHub Personal Access Token (if using private repo)
# Generate at: https://github.com/settings/tokens
# Needs: repo scope
GITHUB_TOKEN=""

# ============================================================
# Optional: Additional Services
# ============================================================

# PageSpeed Insights API Key (optional - has free tier without key)
# Get at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=""

# Ahrefs API (if using competitor analysis)
AHREFS_API_KEY=""

# SEMrush API (if using competitor analysis)
SEMRUSH_API_KEY=""
